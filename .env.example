# =============================================================================
# PandaHistoryAnalitic — Environment Variables
# =============================================================================
# Copy this file to .env.local for local development:
#   cp .env.example .env.local
#
# For production (Vercel): set these in the Vercel dashboard under
#   Settings → Environment Variables
#
# SECURITY NOTE: All VITE_* variables are baked into the JS bundle at build
# time and are visible to anyone who opens browser DevTools.
# Do NOT store real secrets or production credentials here.
# =============================================================================

# ---------------------------------------------------------------------------
# VITE_APP_PASSWORD  (optional)
# ---------------------------------------------------------------------------
# Client-side password gate — lightweight protection for private deployments.
# If this variable is not set or is empty, the password gate is DISABLED
# and anyone can access the app without a password.
#
# WARNING: This is NOT real authentication. The password is embedded in the
# JS bundle and can be read from browser DevTools by any user.
# Use only as a basic deterrent for casual/accidental access.
#
# Set to a value of your choice. Avoid common passwords (e.g. "panda", "1234").
# Example: VITE_APP_PASSWORD=my-private-tool-2024
VITE_APP_PASSWORD=

# ---------------------------------------------------------------------------
# VITE_APP_TITLE  (optional)
# ---------------------------------------------------------------------------
# The title displayed in the app header and browser tab.
# Defaults to "PandaHistoryAnalitic" if not set.
# Example: VITE_APP_TITLE=My History Analyzer
VITE_APP_TITLE=
